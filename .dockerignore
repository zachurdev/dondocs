#=============================================================================
# .dockerignore - Exclude files from Docker build context
#=============================================================================
# Dependencies are installed during the Docker build process.
# node_modules is excluded to keep the build context small.
#=============================================================================

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
*.md
KNOWN_ISSUES.md

# Development files
.vscode
.idea
*.swp
*.swo
*~

# Build artifacts (will be generated in container)
dist
build

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (if any)
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Test files
coverage
.nyc_output

# Temporary files
tmp
temp
*.tmp

# PDF files in root (if any)
*.pdf

# Dependencies (installed during build)
node_modules

# npm cache (include this for offline builds, exclude for online builds)
# npm-cache
