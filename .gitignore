# =============================================================================
# DONDOCS .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# LaTeX Build Artifacts
# -----------------------------------------------------------------------------
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.toc
*.lof
*.lot
*.bbl
*.blg
*.nav
*.snm
*.vrb

# Generated PDF (compile locally)
main.pdf

# -----------------------------------------------------------------------------
# User Data & Sensitive Files (do not commit)
# -----------------------------------------------------------------------------

# Enclosures - add your own PDFs locally
enclosures/*.pdf

# Forms - working PDFs
forms/*.pdf

# Attachments - signatures, seals
attachments/signature.png
attachments/signature.jpg
attachments/signature.pdf

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------

# Claude Code
.claude/

# Node / Vite
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python (if ever added)
__pycache__/
*.pyc
.env
venv/

# Classification configuration (keep example, ignore actual config)
public/classification.config.json

# -----------------------------------------------------------------------------
# Test & Debug Files
# -----------------------------------------------------------------------------
test-*.js
*.test.js
debug-*.log
